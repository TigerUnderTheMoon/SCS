. tempname vifpost

. postfile `vifpost' str32 variable double vif tolerance using "$TABLES/table08
> _vif_observed_2006_2021.dta", replace

. foreach v of local main_rhs {
  2.     local others
  3.     foreach x of local main_rhs {
  4.         if "`x'" != "`v'" local others `others' `x'
  5.     }
  6.     quietly regress `v' `others' i.year if baseline_obs_sample
  7.     scalar vif_value = 1 / (1 - e(r2))
  8.     scalar tolerance_value = 1 / vif_value
  9.     post `vifpost' ("`v'") (vif_value) (tolerance_value)
 10. }

. postclose `vifpost'

. 
. preserve

