. foreach sample in full observed {
  2.     tempname posth
  3.     if "`sample'" == "full" local sampleif "if !missing(id)"
  4.     if "`sample'" == "observed" local sampleif "if is_fitted == 0"
  5.     postfile `posth' str32 variable double N mean median sd min max using 
> "$TABLES/table02_descriptive_statistics_`sample'.dta", replace
  6.     foreach v of local keepvars {
  7.         quietly summarize `v' `sampleif', detail
  8.         post `posth' ("`v'") (r(N)) (r(mean)) (r(p50)) (r(sd)) (r(min)) (r
> (max))
  9.     }
 10.     postclose `posth'
